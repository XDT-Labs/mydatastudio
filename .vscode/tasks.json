{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "clean app dir",
            "type": "shell",
            "command": "rm -fr '${env:HOME}/Library/Application Support/mydata.tools' && rm -fr client/app/*.zip",
            "problemMatcher": []
        },
        {
            "label": "Build aichat (macOS)",
            "type": "shell",
            "command": "cd client/assets/python/aichat && pdm install && python -m PyInstaller -y main.spec --clean --noconfirm && cd dist/aichat && zip -r ../../../../../app/aichat-macos.zip aichat",
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Use Dev Pubspec",
            "type": "shell",
            "command": "cp client/pubspec.dev.yaml client/pubspec.yaml",
            "problemMatcher": []
        },
        {
            "label": "Use Prod Pubspec",
            "type": "shell",
            "command": "cp client/pubspec.prod.yaml client/pubspec.yaml",
            "problemMatcher": []
        }
    ]
}