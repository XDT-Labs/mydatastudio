{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "client (dev)",
            "cwd": "client",
            "request": "launch",
            "type": "dart",
            "preLaunchTask": "Use Dev Pubspec",
        },
        {
            "name": "client (dev w/remote server)",
            "cwd": "client",
            "request": "launch",
            "type": "dart",
            "preLaunchTask": "Use Dev Pubspec",
            "args": [
                "--dart-define=PYTHON_SERVER_URL=http://127.0.0.1:8000"
            ]
        },
        {
            "name": "client (prod)",
            "cwd": "client",
            "request": "launch",
            "type": "dart",
            "preLaunchTask": "Use Prod Pubspec",
            "flutterMode": "release",
            "args": []
        },
        {
            "name": "client (impeller)",
            "cwd": "client",
            "request": "launch",
            "type": "dart",
            "args": [
                "--enable-impeller"
            ]
        },
        {
            "name": "aichat server (python)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/aiserver/main.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/aiserver",
            "justMyCode": true,
            "python": "${workspaceFolder}/aiserver/.venv/bin/python",
            "env": {
                "AICHAT_PORT": "8000"
            }
        },
        {
            "name": "client (profile mode)",
            "cwd": "client",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile",
            "args": []
        }
    ],
    "compounds": [
        {
            "name": "client + server (dev)",
            "configurations": [
                "aichat server (python)",
                "client (dev w/remote server)"
            ]
        }
    ]
}