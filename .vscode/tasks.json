{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "clean app dir",
            "type": "shell",
            "command": "rm -fr '${env:HOME}/Library/Application Support/com.xdtlabs.mydatastudio' && rm -fr client/app/*.zip",
            "problemMatcher": []
        },
        {
            "label": "Build aichat (macOS)",
            "type": "shell",
            "command": "cd aiserver && pdm install && pdm run pyinstaller -y main.spec && mkdir -p ../client/app && rm -f ../client/app/aichat-macos.zip && cd dist/aichat && zip -r ../../../client/app/aichat-macos.zip .",
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Use Dev Pubspec",
            "type": "shell",
            "command": "cp client/pubspec.dev.yaml client/pubspec.yaml",
            "problemMatcher": []
        },
        {
            "label": "Use Prod Pubspec",
            "type": "shell",
            "command": "cp client/pubspec.prod.yaml client/pubspec.yaml",
            "problemMatcher": []
        }
    ]
}